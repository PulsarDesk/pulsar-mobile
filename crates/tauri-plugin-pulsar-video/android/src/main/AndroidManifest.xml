<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Host audio: MediaProjection playback-capture requires RECORD_AUDIO. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Touch haptics: navigator.vibrate() in the client input layer (long-press,
         double-tap, double-tap-drag) is a no-op without this. -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Remote-control cursor: the injected pointer is drawn as a system overlay
         (TYPE_APPLICATION_OVERLAY), captured by MediaProjection so the operator sees it
         in the stream. Android only lists an app under "draw over other apps" if it
         DECLARES this permission — without it canDrawOverlays is always false and the app
         never appears in the settings list. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application>
        <!-- Client: keeps decode + sockets alive when backgrounded. -->
        <service
            android:name=".StreamService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
        <!-- Host (M16): screen capture requires a mediaProjection foreground service. -->
        <service
            android:name=".HostService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />
        <!-- Host control (M16 polish): inject the remote peer's taps/swipes. -->
        <service
            android:name=".PulsarA11yService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/pulsar_a11y" />
        </service>
    </application>
</manifest>

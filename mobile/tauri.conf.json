{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Pulsar",
	"version": "0.1.0-dev.27",
	"identifier": "dev.pulsar.app",
	"build": {
		"frontendDist": "ui"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"label": "main",
				"title": "Pulsar",
				"backgroundColor": "#0D0F15"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
